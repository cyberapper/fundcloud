<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ title }}</title>
  {% include "_tearsheet_style.html.j2" %}
  <style>
    .fc-tabs {
      display: flex; gap: 2px;
      border-bottom: 1px solid var(--rule);
      margin: 24px 0;
      flex-wrap: wrap;
    }
    .fc-tab-btn {
      padding: 10px 18px;
      cursor: pointer;
      border: 0;
      background: transparent;
      color: var(--muted);
      font-family: inherit;
      font-size: 14px;
      font-weight: 500;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
    }
    .fc-tab-btn:hover { color: var(--fg); }
    .fc-tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
    .fc-panel { display: none; }
    .fc-panel.active { display: block; }
    @media print {
      .fc-tabs { display: none; }
      .fc-panel { display: block !important; page-break-before: always; }
      .fc-panel:first-of-type { page-break-before: auto; }
    }
  </style>
</head>
<body>
  <h1>{{ title }}</h1>
  <div class="subtitle">{{ n_assets }} strategies · {{ period_start }} → {{ period_end }} · {{ n_periods }} periods</div>

  <nav class="fc-tabs" role="tablist">
    {% for section in sections %}
    <button class="fc-tab-btn {% if loop.first %}active{% endif %}" role="tab"
            data-target="panel-{{ loop.index0 }}">{{ section.asset }}</button>
    {% endfor %}
  </nav>

  {% for section in sections %}
  <article id="panel-{{ loop.index0 }}" class="fc-panel {% if loop.first %}active{% endif %}" role="tabpanel">
    {% with
      title=section.title,
      period_start=section.period_start,
      period_end=section.period_end,
      n_periods=section.n_periods,
      strategy_label=section.strategy_label,
      benchmark_label=section.benchmark_label,
      stat_cards=section.stat_cards,
      sidebar_sections=section.sidebar_sections,
      cumulative_html=section.cumulative_html,
      drawdown_html=section.drawdown_html,
      rolling_sharpe_html=section.rolling_sharpe_html,
      rolling_alpha_beta_html=section.rolling_alpha_beta_html,
      distribution_html=section.distribution_html,
      monthly_heatmap_html=section.monthly_heatmap_html
    %}
    {% include "_strategy_body.html.j2" %}
    {% endwith %}
  </article>
  {% endfor %}

  <footer>Generated by Fundcloud · {{ generated_at }}</footer>

  <script>
  // Force plotly figures to re-layout when their panel becomes visible.
  // Figures rendered inside `display:none` never measure the container, so
  // their width stays stuck at the initial offscreen value when the tab is
  // shown; `Plotly.Plots.resize` (idempotent, no-op when already sized)
  // fixes the widths the moment the user clicks the tab.
  function _resizePlotsInside(el) {
    if (typeof Plotly === 'undefined') return;
    el.querySelectorAll('.plotly-graph-div').forEach(div => {
      try { Plotly.Plots.resize(div); } catch (e) { /* ignore racing instances */ }
    });
  }
  document.querySelectorAll('.fc-tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.target;
      document.querySelectorAll('.fc-tab-btn').forEach(b => b.classList.toggle('active', b === btn));
      document.querySelectorAll('.fc-panel').forEach(p => {
        const active = p.id === target;
        p.classList.toggle('active', active);
        if (active) _resizePlotsInside(p);
      });
    });
  });
  // Initial sync — some browsers measure 0 width if we don't nudge once.
  window.addEventListener('load', () => {
    document.querySelectorAll('.fc-panel.active').forEach(_resizePlotsInside);
  });
  </script>
</body>
</html>
